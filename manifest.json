{
  "manifest_version": 3,
  "name": "UI Checker — AI Canvas",
  "description": "Local AI UX audits, SEO analysis, and DOM-to-React component cloning. Powered by Gemini Nano + Gemini 2.5 Pro.",
  "version": "2.0.0",
  "minimum_chrome_version": "127",

  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },

  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },

  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "webNavigation",
    "clipboardWrite"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "side_panel": {
    "default_path": "sidepanel/index.html"
  },

  "action": {
    "default_title": "UI Checker — AI Canvas",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },

  "devtools_page": "devtools/devtools.html",

  "sandbox": {
    "pages": ["sandbox/sandbox.html"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/inspector.css"],
      "js": ["content/inspector.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["detector/detect.js", "sandbox/sandbox.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
